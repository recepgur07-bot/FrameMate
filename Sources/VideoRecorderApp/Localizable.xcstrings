    },
    "Ekran kaydı izni gerekli. Adımlar: 1. Sistem Ayarları'nı aç. 2. Gizlilik ve Güvenlik bölümüne git. 3. Ekran Kaydı'nı seç. 4. Bu uygulamayı etkinleştir. 5. Uygulamayı yeniden başlat.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screen recording permission required. Steps: 1. Open System Settings. 2. Go to Privacy & Security. 3. Select Screen Recording. 4. Enable this application. 5. Restart the application."
          }
        }
      }
    },
    "İzin vermek için: 1. Sistem Ayarları'nı aç. 2. Gizlilik ve Güvenlik bölümüne git. 3. Ekran Kaydı'nı seç. 4. Bu uygulamayı etkinleştir. 5. Uygulamayı yeniden başlat. Aşağıdaki 'Ayarları Aç' veya 'İzin İste' düğmelerini kullanabilirsin.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To grant permission: 1. Open System Settings. 2. Go to Privacy & Security. 3. Select Screen Recording. 4. Enable this application. 5. Restart the application. You can use the 'Open Settings' or 'Request Permission' buttons below."
          }
        }
      }
    }
  },
